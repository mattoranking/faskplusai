# ──────────────────────────────────────────────
# Copy to .env and fill in real values
# Docker Compose reads .env automatically.
# ──────────────────────────────────────────────

# Database credentials (shared by db service + backend)
POSTGRES_USER=faskplusai
POSTGRES_PASSWORD=choose_a_strong_password
POSTGRES_DB=faskplusai_dev_db

# Backend
FASKPLUSAI_ENV=development
FASKPLUSAI_JWT_SECRET_KEY=change_me_in_production
FASKPLUSAI_CORS_ORIGINS=https://faskplusai.dev

# APIs
GEMINI_API_KEY=your_gemini_api_key_here

# Frontend
NEXT_PUBLIC_API_URL=https://api.faskplusai.dev
NODE_ENV=development

